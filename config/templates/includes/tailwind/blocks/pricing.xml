<properties xmlns="http://schemas.sulu.io/template/template"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="blocks" default-type="pricing">
        <types>
            <type name="pricing">
                <meta>
                    <title>Pricing</title>
                </meta>
                <properties>
                    <property name="subline" type="text_line">
                        <meta>
                            <title>Subline</title>
                        </meta>
                    </property>
                    <property name="headline" type="text_line">
                        <meta>
                            <title>Headline</title>
                        </meta>
                        <params>
                            <param name="headline" value="true"/>
                        </params>
                    </property>
                    <property name="description" type="text_editor">
                        <meta>
                            <title>Beschreibung</title>
                        </meta>
                        <params>
                            <param name="table" value="false"/>
                            <param name="link" value="true"/>
                        </params>
                    </property>
                    <block name="plans" default-type="plan" minOccurs="1" maxOccurs="3">
                        <meta>
                            <title>Plans</title>
                        </meta>
                        <types>
                            <type name="plan">
                                <meta>
                                    <title>Plan</title>
                                </meta>
                                <properties>
                                    <property name="name" type="text_line">
                                        <meta>
                                            <title>Name</title>
                                        </meta>
                                    </property>
                                    <property name="price" type="text_line">
                                        <meta>
                                            <title>Price</title>
                                        </meta>
                                    </property>
                                    <property name="description" type="text_line">
                                        <meta>
                                            <title>Description</title>
                                        </meta>
                                    </property>
                                    <property name="popular" type="checkbox">
                                        <meta>
                                            <title>Popular</title>
                                        </meta>
                                    </property>
                                    <property name="popularLabel" type="text_line">
                                        <meta>
                                            <title>Popular Label</title>
                                        </meta>
                                    </property>
                                    <property name="url" type="url">
                                        <meta>
                                            <title>URL</title>
                                        </meta>
                                    </property>
                                    <property name="buttonText" type="text_line">
                                        <meta>
                                            <title>Button Text</title>
                                        </meta>
                                    </property>
                                    <block name="features" default-type="feature" minOccurs="0" maxOccurs="10">
                                        <meta>
                                            <title>Features</title>
                                        </meta>
                                        <types>
                                            <type name="feature">
                                                <meta>
                                                    <title>Feature</title>
                                                </meta>
                                                <properties>
                                                    <property name="text" type="text_line">
                                                        <meta>
                                                            <title>Feature</title>
                                                        </meta>
                                                    </property>
                                                </properties>
                                            </type>
                                        </types>
                                    </block>
                                </properties>
                            </type>
                        </types>
                    </block>
                </properties>
            </type>
        </types>
    </block>
</properties>
