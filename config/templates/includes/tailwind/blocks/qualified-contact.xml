            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="blocks" default-type="qualified-contact" minOccurs="0">
        <types>
            <type name="qualified-contact">
                <meta>
                    <title lang="en">Qualified Contact Form</title>
