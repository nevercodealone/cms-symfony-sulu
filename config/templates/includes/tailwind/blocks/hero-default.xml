<properties xmlns="http://schemas.sulu.io/template/template"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="blocks" default-type="hero-default">
        <types>
            <type name="hero-default">
                <meta>
                    <title>Hero Default</title>
                </meta>
                <properties>
                    <property name="subline" type="text_line">
                        <meta>
                            <title>Subline</title>
                        </meta>
                    </property>
                    <property name="headline" type="text_line">
                        <meta>
                            <title>Headline</title>
                        </meta>
                        <params>
                            <param name="headline" value="true"/>
                        </params>
                    </property>
                    <property name="description" type="text_editor">
                        <meta>
                            <title>Beschreibung</title>
                        </meta>
                        <params>
                            <param name="table" value="false"/>
                            <param name="link" value="true"/>
                        </params>
                    </property>
                    <property name="actionText" type="text_line" colspan="6">
                        <meta>
                            <title>Button Text</title>
                        </meta>
                    </property>
                    <property name="url" type="url" colspan="6">
                        <meta>
                            <title>Button URL</title>
                        </meta>
                    </property>
                    <property name="actionText2" type="text_line" colspan="6">
                        <meta>
                            <title>Button 2 Text</title>
                        </meta>
                    </property>
                    <property name="url2" type="url" colspan="6">
                        <meta>
                            <title>Button 2 URL</title>
                        </meta>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
