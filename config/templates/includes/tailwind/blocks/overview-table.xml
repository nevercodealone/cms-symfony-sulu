<properties xmlns="http://schemas.sulu.io/template/template"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="blocks" default-type="overview-table">
        <types>
            <type name="overview-table">
                <meta>
                    <title>Overview Table</title>
                </meta>
                <properties>
                    <property name="subline" type="text_line">
                        <meta>
                            <title>Subline</title>
                        </meta>
                    </property>
                    <property name="headline" type="text_line">
                        <meta>
                            <title>Headline</title>
                        </meta>
                        <params>
                            <param name="headline" value="true"/>
                        </params>
                    </property>
                    <property name="description" type="text_editor">
                        <meta>
                            <title>Beschreibung</title>
                        </meta>
                        <params>
                            <param name="table" value="false"/>
                            <param name="link" value="true"/>
                        </params>
                    </property>
                    <block name="headers" default-type="header" minOccurs="1" maxOccurs="6">
                        <meta>
                            <title>Headers</title>
                        </meta>
                        <types>
                            <type name="header">
                                <meta>
                                    <title>Header</title>
                                </meta>
                                <properties>
                                    <property name="text" type="text_line">
                                        <meta>
                                            <title>Header Text</title>
                                        </meta>
                                    </property>
                                </properties>
                            </type>
                        </types>
                    </block>
                    <block name="rows" default-type="row" minOccurs="1" maxOccurs="50">
                        <meta>
                            <title>Rows</title>
                        </meta>
                        <types>
                            <type name="row">
                                <meta>
                                    <title>Row</title>
                                </meta>
                                <properties>
                                    <block name="cells" default-type="cell" minOccurs="1" maxOccurs="6">
                                        <meta>
                                            <title>Cells</title>
                                        </meta>
                                        <types>
                                            <type name="cell">
                                                <meta>
                                                    <title>Cell</title>
                                                </meta>
                                                <properties>
                                                    <property name="text" type="text_line">
                                                        <meta>
                                                            <title>Cell Text</title>
                                                        </meta>
                                                    </property>
                                                </properties>
                                            </type>
                                        </types>
                                    </block>
                                </properties>
                            </type>
                        </types>
                    </block>
                </properties>
            </type>
        </types>
    </block>
</properties>
