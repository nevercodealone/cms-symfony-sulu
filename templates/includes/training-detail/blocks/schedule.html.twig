<!-- schedule.html.twig -->
{% if (content.headline is defined and content.headline is not empty) or 
     (content.dayOneHeadline is defined and content.dayOneHeadline != '' and content.dayOneItems is defined and content.dayOneItems is not empty) or
     (content.dayTwoHeadline is defined and content.dayTwoHeadline != '' and content.dayTwoItems is defined and content.dayTwoItems is not empty) %}
<div class="bg-gray-50 rounded-lg p-6 lg:p-8">
    {% if content.headline is defined and content.headline is not empty %}
        <h3 class="text-xl lg:text-2xl font-bold text-gray-900 mb-6">{{ content.headline }}</h3>
    {% endif %}
    
    <div class="space-y-8">
        {% if content.dayOneHeadline is defined and content.dayOneHeadline != '' and content.dayOneItems is defined and content.dayOneItems is not empty %}
            <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
                    {{ content.dayOneHeadline }}
                </h4>
                <div class="space-y-3">
                    {% for item in content.dayOneItems %}
                        <div class="flex items-start p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow">
                            <div class="flex-shrink-0 mr-4">
                                {% if item.status == 'team' %}
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
                                        </svg>
                                    </div>
                                {% elseif item.status == 'live' %}
                                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M3.5 9a10 10 0 0 1 17 0"/>
                                            <path d="M6.5 9a6 6 0 0 1 11 0"/>
                                            <path d="M12 9v5"/>
                                            <path d="m9 21 3-7 3 7"/>
                                            <path d="M8 17h8"/>
                                        </svg>
                                    </div>
                                {% else %}
                                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                                        </svg>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="flex-1">
                                <h5 class="text-base font-medium text-gray-900">{{ item.title }}</h5>
                                <p class="mt-1 text-sm text-gray-600">
                                    {% if item.status == 'team' %}
                                        Teamarbeit
                                    {% elseif item.status == 'live' %}
                                        Live-Session
                                    {% else %}
                                        Theorie
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
        
        {% if content.dayTwoHeadline is defined and content.dayTwoHeadline != '' and content.dayTwoItems is defined and content.dayTwoItems is not empty %}
            <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
                    {{ content.dayTwoHeadline }}
                </h4>
                <div class="space-y-3">
                    {% for item in content.dayTwoItems %}
                        <div class="flex items-start p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow">
                            <div class="flex-shrink-0 mr-4">
                                {% if item.status == 'team' %}
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
                                        </svg>
                                    </div>
                                {% elseif item.status == 'live' %}
                                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M3.5 9a10 10 0 0 1 17 0"/>
                                            <path d="M6.5 9a6 6 0 0 1 11 0"/>
                                            <path d="M12 9v5"/>
                                            <path d="m9 21 3-7 3 7"/>
                                            <path d="M8 17h8"/>
                                        </svg>
                                    </div>
                                {% else %}
                                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                                        </svg>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="flex-1">
                                <h5 class="text-base font-medium text-gray-900">{{ item.title }}</h5>
                                <p class="mt-1 text-sm text-gray-600">
                                    {% if item.status == 'team' %}
                                        Teamarbeit
                                    {% elseif item.status == 'live' %}
                                        Live-Session
                                    {% else %}
                                        Theorie
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endif %}
<!-- end schedule.html.twig -->