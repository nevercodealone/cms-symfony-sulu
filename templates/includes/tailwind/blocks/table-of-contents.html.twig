<!-- table-of-contents.html.twig -->
{% if content.headline is defined and content.headline is not empty %}
  {% include "includes/tailwind/includes/headline.html.twig" with {
    'content': content,
    'loopIndex': loopIndex,
    'isFirstHeadline': false
  } %}
{% endif %}
<nav aria-label="table-of-contents" class="toc mb-8 description-list">
  <ul class="space-y-2" role="list" aria-labelledby="toc-heading">
    {% for section in headlines %}
      {% if section.headline is defined %}
        {% set htmlId = section.headline|lower
          |replace({'ä': 'a', 'ö': 'o', 'ü': 'u', 'ß': 'ss'})
          |replace({' ': '-'})
          |replace({'/[^a-z0-9\\-]/': ''}) %}
        <li>
          <a
            href="#{{ htmlId }}"
            class="text-blue-800 hover:text-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded transition-colors"
            {% if loop.first %}aria-current="true"{% endif %}
          >
            {{ section.headline }}
          </a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</nav>
<!-- end table-of-contents.html.twig -->
