<!-- icon-grid.html.twig -->
<div class="py-24 sm:py-32">
  <div class="mx-auto max-w-xl px-6 lg:max-w-7xl lg:px-8">
    {% if content.subline %}
      <h3 class="text-base font-semibold leading-7 text-green-600">
        {{ content.subline }}
      </h3>
    {% endif %}
    <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      {{ content.headline }}
    </p>
    <p class="mt-6 text-lg leading-8 text-gray-600">
      {{ content.description|raw }}
    </p>
    <div class="mt-16 grid grid-cols-2 gap-x-12 gap-y-16 lg:grid-cols-4">
      {% for item in content.items %}
        <div>
          <div class="mb-8 flex h-10 w-10 items-center justify-center rounded-lg bg-green-700">
            <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-base font-semibold leading-7 text-gray-900">
            {{ item.headline }}
          </h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">
            {{ item.description|raw }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
<!-- end icon-grid.html.twig -->
