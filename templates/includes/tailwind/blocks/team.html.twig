<!-- team.html.twig -->
<div class="max-w-screen-lg mx-auto text-gray-800 sm:text-lg">
  {% if content.headline is defined and content.headline is not empty %}
    <h2 class="text-3xl text-gray-900 font-bold tracking-tight sm:text-4xl">{{ content.headline }}</h2>
    <div class="mt-6">{{ content.description|raw }}</div>
  {% endif %}
  <ul role="list" class="mt-10 grid grid-cols-1 gap-x-4 sm:grid-cols-2 lg:grid-cols-3 sm:gap-y-12 sm:space-y-0">
    {% if content.organisation is not empty %}
      {% for item in content.organisation %}
        {% if item.avatar.thumbnails['400x400'] is defined and item.avatar.thumbnails['400x400'] is not empty %}
          {% set source = item.avatar.thumbnails['team'] %}
          <li>
            <article class="space-y-2">
              <div>
                <img class="w-full rounded-lg object-cover shadow-lg" src="{{ source }}" alt="{{ item.fullName }}">
              </div>
              <div class="space-y-1 text-lg font-medium leading-6">
                <h3 class="text-xl text-gray-900">{{ item.fullName }}</h3>
                <p class="text-base text-green-800">{{ item.positionName }}</p>
              </div>
              {% if item.contactDetails.socialMedia is not empty %}
                <ul role="list" class="flex space-x-5 p-0" aria-label="Social Link Liste">
                  {% for social in item.contactDetails.socialMedia %}
                    <li>
                      {% include 'includes/tailwind/link-social-media.html.twig' with {'socialLink': social.username, 'fullName': item.fullName } %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
              <p class="text-base text-gray-800">
                {{ item.note }}
              </p>
            </article>
          </li>
        {% endif %}
      {% endfor %}
    {% endif %}
  </ul>
</div>
<!-- end team.html.twig -->
