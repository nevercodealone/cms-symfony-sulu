<!-- link-grid.html.twig -->
<div class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    {% if content.subline %}
      <h3 class="text-base font-semibold leading-7 text-green-600">
        {{ content.subline }}
      </h3>
    {% endif %}
    <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      {{ content.headline }}
    </p>
    <p class="mt-6 text-lg leading-8 text-gray-600">
      {{ content.description|raw }}
    </p>
    <dl class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {% for item in content.items %}
        <a href="{{ item.url }}" class="flex flex-col items-center text-center p-6 bg-white rounded-xl shadow-sm hover:bg-gray-50">
          <dt class="order-2 mt-4 font-medium text-gray-900">
            {{ item.headline }}
          </dt>
          <dd class="order-1 text-gray-500">
            {{ item.description }}
          </dd>
        </a>
      {% endfor %}
    </dl>
  </div>
</div>
<!-- end link-grid.html.twig -->
